---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: kopf-controller
  namespace: {{ core_ns }}

---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: kopf-controller
rules:
  - apiGroups: [""]
    resources: ["pods"]
    verbs: ["get", "list", "watch", "patch"]

  - apiGroups: [""]
    resources: ["pods/ephemeralcontainers"]
    verbs: ["patch", "update"]

  - apiGroups: [""]
    resources: ["pods/exec"]
    verbs: ["create"]

  - apiGroups: [""]
    resources: ["events"]
    verbs: ["create", "patch", "update"]

  - apiGroups: [""]
    resources: ["services"]
    verbs: ["get", "list", "watch", "create", "patch", "update"]

  - apiGroups: ["apps"]
    resources: ["deployments"]
    verbs: ["get", "list", "watch", "create", "patch", "update"]

---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: kopf-controller
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: kopf-controller
subjects:
  - kind: ServiceAccount
    name: kopf-controller
    namespace: {{ core_ns }}

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: kopf-controller
  namespace: {{ core_ns }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: kopf-controller
  template:
    metadata:
      labels:
        app: kopf-controller
    spec:
      serviceAccountName: kopf-controller
      containers:
        - name: controller
          image: "{{ kopf_image }}"
          imagePullPolicy: "{{ image_pull_policy | default('IfNotPresent') }}"
          env:
            - name: CORE_NS
              value: "{{ core_ns }}"
            - name: UE_MAPPER_LIMIT
              value: "{{ ue_mapper_limit | default('2000') }}"
            - name: PROBE_IMAGE
              value: "{{ probe_image }}"
            - name: EXPORTER_PORT
              value: "{{ exporter_port | default('9100') }}"
            - name: EXPORTER_PATH
              value: "{{ exporter_path | default('/latency') }}"
            - name: MATCH_DEBUG
              value: "{{ match_debug | default('0') }}"
            - name: PROBE_MODE
              value: "{{ probe_mode | default('both') }}"
            - name: PACKET_PAIRING
              value: "{{ packet_pairing | default('0') }}"
            - name: DRY_RUN
              value: "{{ dry_run | default('0') }}"
            - name: GNB_LATENCY_MODE
              value: "{{ gnb_latency_mode | default('E2E') }}"
            - name: UPF_LATENCY_MODE
              value: "{{ upf_latency_mode | default('BOTH') }}"
            - name: PACKET_PAIRER_NAME
              value: "{{ packet_pairer_name | default('ebpf-latency-probe-pairer') }}"
            - name: PACKET_PAIRER_SERVICE_NAME
              value: "{{ packet_pairer_service_name | default(packet_pairer_name | default('ebpf-latency-probe-pairer')) }}"
            - name: PACKET_PAIRER_METRICS_PORT
              value: "{{ packet_pairer_metrics_port | default('9200') }}"
            - name: PACKET_PAIRER_METRICS_PATH
              value: "{{ packet_pairer_metrics_path | default('/metrics') }}"
            - name: PACKET_PAIRER_PORT
              value: "{{ packet_pairer_port | default('9201') }}"
{% if packet_pairer_image is defined and packet_pairer_image | length > 0 %}
            - name: PACKET_PAIRER_IMAGE
              value: "{{ packet_pairer_image }}"
{% endif %}
{% if ue_mapper_url is defined and ue_mapper_url | length > 0 %}
            - name: UE_MAPPER_URL
              value: "{{ ue_mapper_url }}"
{% endif %}
{% if probe_iface is defined and probe_iface | length > 0 %}
            - name: PROBE_IFACE
              value: "{{ probe_iface }}"
{% endif %}
          resources:
            requests:
              cpu: "{{ cpu_request | default('50m') }}"
              memory: "{{ mem_request | default('64Mi') }}"
            limits:
              cpu: "{{ cpu_limit | default('500m') }}"
              memory: "{{ mem_limit | default('256Mi') }}"
