{#
  ueransim-gnb-values.yaml.j2
  Generates Helm values override for ueransim gNB chart (free5gc)
#}
{%- macro resolve_sd(sd) -%}
  {%- if sd == 'EMPTY' -%}0xFFFFFF
  {%- else -%}0x{{ '%06x' | format(sd | int(base=16)) }}
  {%- endif -%}
{%- endmacro -%}

global:
  n2network:
    enabled: true
    masterIf: "{{ nic_interface }}"
    gatewayIP: ""
    excludeIP: ""
  n3network:
    enabled: true
    masterIf: "{{ nic_interface }}"
    gatewayIP: ""
    excludeIP: ""

gnb:
  enabled: true

  n2if:
    ipAddress: 0.0.0.0   # listen on all interfaces (Flannel eth0)
  n3if:
    ipAddress: {{ net.n3.gnb_ip }}

  amf:
    n2if:
      ipAddress: {{ net.n2.amf_ip }}  # -> "free5gc-free5gc-amf-amf-n2" service DNS
      port: {{ net.n2.amf_ngap_port }}
    service:
      ngap:
        enabled: true   # use NGAP NodePort service instead of ipvlan

  nodeName: "{{ ran_node_name }}"

  configuration: |-
    mcc: '{{ profile.plmn.mcc }}'
    mnc: '{{ profile.plmn.mnc }}'
    nci: '0x000000010'
    idLength: 32
    tac: {{ profile.plmn.tac | int }}
    slices:
{% for slice in profile.slices %}
      - sst: {{ slice.sst | int }}
        sd: {{ resolve_sd(slice.sd) }}
{% endfor %}
    ignoreStreamIds: true

ue:
  enabled: false  # UEs deployed separately, one release per UE
