{#
  ueransim-gnb-values-oai.yaml.j2
#}

{%- macro resolve_sd(sd) -%}
  {%- if sd == 'EMPTY' -%}0xFFFFFF
  {%- else -%}0x{{ '%06x' | format(sd | int(base=16)) }}
  {%- endif -%}
{%- endmacro -%}

global:
  n2network:
    enabled: false   # FIX: stop ipvlan auto-generation
  n3network:
    enabled: false   # FIX: stop ipvlan auto-generation

gnb:
  enabled: true

  n2if:
    ipAddress: 0.0.0.0

  n3if:
    ipAddress: {{ net.gnb_n3_ip }}

  amf:
    n2if:
      ipAddress: {{ net.amf_ip }}
      port: {{ net.amf_port }}
    service:
      ngap:
        enabled: true

  configuration: |-
    mcc: '{{ profile.plmn.mcc }}'
    mnc: '{{ profile.plmn.mnc }}'
    nci: '0x000000010'
    idLength: 32
    tac: {{ profile.plmn.tac | int }}
    slices:
{% for slice in profile.slices %}
      - sst: {{ slice.sst | int }}
        sd: {{ resolve_sd(slice.sd) }}
{% endfor %}
    ignoreStreamIds: true

  k8s.v1.cni.cncf.io/networks:
    - name: ueransim-gnb-net
      interface: n2
    - name: ueransim-gnb-net
      interface: n3

ue:
  enabled: false

nodeSelector:
  kubernetes.io/hostname: "{{ ran_node_name }}"
