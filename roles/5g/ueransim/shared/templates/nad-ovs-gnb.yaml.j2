---
# ============================================================
# NetworkAttachmentDefinition for gNB
# N2 and N3 both on n3br (same subnet as OAI)
# ============================================================

apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: ueransim-gnb-net
  namespace: {{ ran_ns | default('oai') }}
spec:
  config: |
    {
      "cniVersion": "0.3.1",
      "name": "ueransim-gnb-net",
      "type": "ovs",
      "bridge": "{{ oai_config.n3_bridge }}",
      "ipMasq": false,
      "isGateway": false,
      "mtu": 1500,
      "ipam": {
        "type": "static",
        "addresses": [
          {
            "address": "{{ oai_config.gnb_n3_ip }}/24",
            "gateway": "{{ oai_config.gateway | default('192.168.3.1') }}"
          }
        ]
      }
    }
