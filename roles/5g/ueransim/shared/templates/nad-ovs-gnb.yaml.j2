---
# ============================================================
# NetworkAttachmentDefinition for gNB
# N2 and N3 both on n3br (same subnet as OAI)
# ============================================================

apiVersion: k8s.cni.cncf.io/v1
kind: NetworkAttachmentDefinition
metadata:
  name: ueransim-gnb-net
  namespace: {{ ran_ns | default('oai') }}
spec:
  config: |
    {
      "cniVersion": "0.3.1",
      "name": "ueransim-gnb-net",
      "type": "ovs",
      "bridge": "n3br",
      "ipMasq": false,
      "isGateway": false,
      "mtu": 1500
    }