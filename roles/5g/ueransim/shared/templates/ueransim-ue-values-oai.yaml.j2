---
replicaCount: 1

image:
  repository: aligungr/ueransim
  pullPolicy: IfNotPresent
  tag: "latest"

podSecurityContext:
  privileged: true
  capabilities:
    add:
      - NET_ADMIN

containers:
  ue:
    securityContext:
      privileged: true
      capabilities:
        add:
          - NET_ADMIN
    resources:
      limits:
        cpu: 300m
        memory: 256Mi
      requests:
        cpu: 100m
        memory: 128Mi

config:
  imsi: "{{ profile.plmn.mcc }}{{ profile.plmn.mnc }}{{ ue_data.imsi_suffix }}"
  key: "{{ profile.security.full_key }}"
  opc: "{{ profile.security.opc }}"
  sst: {{ slice_data.sst | int }}
  sd: "{{ '0x%06x' | format(slice_data.sd | int) if slice_data.sd | int else '000000' }}"
  gnbSearchList:
    - "ueransim-gnb"
    - "ueransim-gnb.{{ ran_ns | default('oai') }}.svc.cluster.local"

affinity: {}
