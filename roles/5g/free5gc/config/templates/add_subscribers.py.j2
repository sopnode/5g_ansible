#!/usr/bin/env python3
# Generated by Ansible from 5G profile: {{ fiveg_profile | default('default') }}
# DO NOT EDIT MANUALLY

import argparse
import free5gc_db

parser = argparse.ArgumentParser()
parser.add_argument("-m", "--mongo", help="Mongodb address", default='mongodb')
parser.add_argument("-a", "--action", help="Action to be performed (list|add|clean)", default='list')
args = parser.parse_args()

free5gc_instance = free5gc_db.Free5gc(args.mongo, 27017)

PLMN = "{{ profile.plmn.mcc }}{{ profile.plmn.mnc }}"

# Slices definition from profile
SLICES = {
{% for slice in profile.slices %}
    "{{ slice.name }}": {
        "sst": {{ slice.sst | int }},
        "sd": "{{ 'ffffff' if slice.sd == 'EMPTY' else '%06x' | format(slice.sd | int(base=16)) }}",
        "sd_key": "{{ '%02x%s' | format(slice.sst | int, 'ffffff' if slice.sd == 'EMPTY' else '%06x' | format(slice.sd | int(base=16))) }}",
        "dnn": "{{ slice.dnn }}",
        "uplink": "{{ slice.bandwidth.uplink }}",
        "downlink": "{{ slice.bandwidth.downlink }}",
        "five_qi": {{ slice.qos.five_qi | int }},
        "arp_priority": {{ slice.qos.arp.priority_level | int }},
    },
{% endfor %}
}

# UEs definition from profile
UES = {
{% for ue_name, ue in profile.ues.items() %}
    "{{ ue_name }}": {
        "imsi": "{{ profile.plmn.mcc }}{{ profile.plmn.mnc }}{{ ue.imsi_suffix }}",
        "slice": "{{ ue.slice }}",
        "key": "{{ profile.security.full_key }}",
        "opc": "{{ profile.security.opc }}",
    },
{% endfor %}
}


def build_subscriber_data(ue_name, ue):
    imsi_full = f"imsi-{ue['imsi']}"
    slice_name = ue["slice"]
    s = SLICES[slice_name]
    sd = s["sd"]
    sst = s["sst"]
    sd_key = s["sd_key"]
    snssai_key = f"0{sd_key}"
    dnn = s["dnn"]

    return {
        'subscriptionData.provisionedData.smfSelectionSubscriptionData': [{
            'servingPlmnId': PLMN,
            'subscribedSnssaiInfos': {
                snssai_key: {'dnnInfos': [{'dnn': dnn}]}
            },
            'ueId': imsi_full
        }],
        'subscriptionData.provisionedData.smData': [{
            'dnnConfigurations': {
                dnn: {
                    '5gQosProfile': {
                        '5qi': float(s["five_qi"]),
                        'arp': {
                            'preemptCap': '',
                            'preemptVuln': '',
                            'priorityLevel': float(s["arp_priority"])
                        },
                        'priorityLevel': float(s["arp_priority"])
                    },
                    'pduSessionTypes': {
                        'allowedSessionTypes': ['IPV4'],
                        'defaultSessionType': 'IPV4'
                    },
                    'sessionAmbr': {
                        'downlink': s["downlink"],
                        'uplink': s["uplink"]
                    },
                    'sscModes': {
                        'allowedSscModes': ['SSC_MODE_2', 'SSC_MODE_3'],
                        'defaultSscMode': 'SSC_MODE_1'
                    }
                }
            },
            'servingPlmnId': PLMN,
            'singleNssai': {'sd': sd, 'sst': float(sst)},
            'ueId': imsi_full
        }],
        'policyData.ues.smData': [{
            'smPolicySnssaiData': {
                snssai_key: {
                    'smPolicyDnnData': {dnn: {'dnn': dnn}},
                    'snssai': {'sd': sd, 'sst': float(sst)}
                }
            },
            'ueId': imsi_full
        }],
        'policyData.ues.amData': [{
            'subscCats': ['free5gc'],
            'ueId': imsi_full
        }],
        'subscriptionData.provisionedData.amData': [{
            'gpsis': [f'msisdn-0900000000'],
            'nssai': {
                'defaultSingleNssais': [{'sd': sd, 'sst': float(sst)}]
            },
            'servingPlmnId': PLMN,
            'subscribedUeAmbr': {'downlink': '2 Gbps', 'uplink': '1 Gbps'},
            'ueId': imsi_full
        }],
        'subscriptionData.authenticationData.authenticationSubscription': [{
            'authenticationManagementField': '8000',
            'authenticationMethod': '5G_AKA',
            'milenage': {'op': {'encryptionAlgorithm': 0.0, 'encryptionKey': 0.0, 'opValue': ''}},
            'opc': {
                'encryptionAlgorithm': 0.0,
                'encryptionKey': 0.0,
                'opcValue': ue['opc']
            },
            'permanentKey': {
                'encryptionAlgorithm': 0.0,
                'encryptionKey': 0.0,
                'permanentKeyValue': ue['key']
            },
            'sequenceNumber': '16f3b3f70fc2',
            'ueId': imsi_full
        }],
    }


if args.action == 'list':
    subscribers_data = free5gc_instance.get_subscribers()
    for key, value in subscribers_data.items():
        print(key)
        for item in value:
            print(item)
        print()
    print("Summary:")
    for key, value in subscribers_data.items():
        print(f"{key}: {len(value)}")

elif args.action == 'clean':
    free5gc_instance.delete_all_subscribers()
    print("All subscribers deleted.")

elif args.action == 'add':
    for ue_name, ue in UES.items():
        subscriber_data = build_subscriber_data(ue_name, ue)
        result = free5gc_instance.add_subscriber(subscriber_data)
        if result:
            print(f"Subscriber {ue_name} ({ue['imsi']}) added.")
        else:
            print(f"Error adding subscriber {ue_name}.")
